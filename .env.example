# Токен від alerts.in.ua
ALERTS_TOKEN=your_token_here

# false = реальний API, true (або не встановлено) = моки
VITE_USE_MOCK=true

# Ваш GitHub username і назва репо (для читання history.json)
# Потрібні лише якщо VITE_USE_MOCK=false
VITE_GITHUB_USER=your_github_username
VITE_REPO_NAME=your_repo_name